# ===== GitCast Docker 环境变量 =====

# 应用
APP_NAME=GitCast
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# GitHub
GITHUB_TOKEN=your-github-token
GITHUB_API_BASE=https://api.github.com
GITHUB_API_RATE_LIMIT_PER_HOUR=5000

# LLM (SiliconFlow)
LLM_PROVIDER=siliconflow
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_API_KEY=your-siliconflow-api-key
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# TTS
TTS_ENGINE=azure
TTS_VOICE=zh-CN-XiaoxiaoMultilingualNeural
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastasia
COSYVOICE_API_BASE=http://localhost:50000
COSYVOICE_DEFAULT_VOICE=default

# 数据库（Docker Compose 内部网络）
DATABASE_URL=postgresql+asyncpg://gitcast:gitcast@postgres:5432/gitcast
REDIS_URL=redis://redis:6379/0

# 存储
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/storage
STORAGE_BASE_URL=http://localhost:8000/storage

# 安全
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 业务
DAILY_ARTICLE_LIMIT=5
FREE_API_QUOTA_PER_MONTH=50
API_PRICE_PER_ARTICLE=0.5
CONTENT_REVIEW_SAMPLE_RATE=0.1

# 发布平台
ENABLED_PUBLISHERS=ximalaya,xiaoyuzhou,bilibili,wechat
XIMALAYA_APP_KEY=your-ximalaya-app-key
XIMALAYA_APP_SECRET=your-ximalaya-app-secret
XIAOYUZHOU_TOKEN=your-xiaoyuzhou-token
BILIBILI_SESSDATA=your-bilibili-sessdata
BILIBILI_CSRF=your-bilibili-csrf
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# PostgreSQL
POSTGRES_DB=gitcast
POSTGRES_USER=gitcast
POSTGRES_PASSWORD=gitcast
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# n8n
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=change-me
N8N_HOST=0.0.0.0
N8N_ENCRYPTION_KEY=change-this-encryption-key

# Grafana
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Prometheus
PROMETHEUS_PORT=9090
