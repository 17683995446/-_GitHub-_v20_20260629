# GitCast 环境变量模板
# 复制为 .env 并填入真实值，.env 文件严禁提交到 Git

# ===== 应用配置 =====
APP_NAME=GitCast
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=DEBUG

# ===== GitHub API =====
# https://github.com/settings/tokens 创建 token（只需 public_repo 读取权限）
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_API_BASE=https://api.github.com
GITHUB_API_RATE_LIMIT_PER_HOUR=5000

# ===== LLM 配置 =====
# 硅基流动 SiliconFlow
LLM_PROVIDER=siliconflow
LLM_API_BASE=https://api.siliconflow.cn/v1
LLM_API_KEY=sk_your_siliconflow_api_key_here
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# ===== TTS 配置 =====
TTS_ENGINE=azure  # azure | cosyvoice | edge
TTS_VOICE=zh-CN-XiaoxiaoMultilingualNeural

# Azure TTS
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastasia

# CosyVoice2 自托管
COSYVOICE_API_BASE=http://localhost:50000
COSYVOICE_DEFAULT_VOICE=default

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://gitcast:gitcast@localhost:5432/gitcast
REDIS_URL=redis://localhost:6379/0

# ===== 对象存储 =====
STORAGE_TYPE=local  # local | s3 | oss
STORAGE_LOCAL_PATH=./storage
STORAGE_BASE_URL=http://localhost:8000/storage

# ===== 发布平台 =====
# 喜马拉雅
XIMALAYA_APP_KEY=your_app_key
XIMALAYA_APP_SECRET=your_app_secret

# 小宇宙
XIAOYUZHOU_TOKEN=your_token

# B站
BILIBILI_SESSDATA=your_sessdata
BILIBILI_CSRF=your_csrf

# 微信公众号
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# ===== 安全 =====
SECRET_KEY=change_this_to_random_64_char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 业务配置 =====
DAILY_ARTICLE_LIMIT=5
FREE_API_QUOTA_PER_MONTH=50
API_PRICE_PER_ARTICLE=0.5
CONTENT_REVIEW_SAMPLE_RATE=0.1
